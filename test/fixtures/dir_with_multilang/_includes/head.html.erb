<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta title="<%= "#{site[:title]}-#{page[:title]}" %>" >
<% page[:translations].each do |lang, url| %>
  <link rel="alternate" hreflang="<%= lang %>" href="<%= url %>">
<% end %>
<% if og_type %>
<meta og:type="<%= og_type %>" >
<% end %>
